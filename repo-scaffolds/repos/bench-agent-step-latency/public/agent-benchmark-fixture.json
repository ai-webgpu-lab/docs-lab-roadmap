        { "id": "filter-priority", "tool": "filter_cards", "target": "status:waiting+priority:high", "latencyMs": 34, "effect": "Filtered waiting cards to high priority." },
        { "id": "copy-owner", "tool": "copy_field", "target": "GPU-17.owner", "latencyMs": 26, "effect": "Copied owner alex.", "draftLine": "Waiting GPU ticket owner: alex" }
      ]
    },
    {
      "id": "record-lab-note",
      "goal": "Draft a short local note for the active lab card.",
      "steps": [
        { "id": "open-lab-card", "tool": "open_panel", "target": "card.LAB-42", "latencyMs": 30, "effect": "Opened LAB-42 detail panel." },
        { "id": "copy-priority", "tool": "copy_field", "target": "LAB-42.priority", "latencyMs": 24, "effect": "Copied medium priority tag.", "draftLine": "LAB-42 priority: medium" },
        { "id": "write-local-note", "tool": "write_note", "target": "local-draft", "latencyMs": 36, "effect": "Wrote draft line for capture readiness.", "draftLine": "LAB-42 note: capture nightly readiness deltas." }
      ]
    },
    {
      "id": "toggle-audit-safe",
      "goal": "Toggle audit mode and confirm local-only capture policy is preserved.",
      "steps": [
        { "id": "open-audit-settings", "tool": "open_panel", "target": "settings.audit", "latencyMs": 30, "effect": "Opened audit settings." },
        { "id": "policy-check", "tool": "copy_field", "target": "settings.capturePolicy", "latencyMs": 24, "effect": "Read local-only capture policy.", "draftLine": "Capture policy remains local-only.", "failureKey": "policy-check", "fallbackDraftLine": "Capture policy check requires manual review on fallback." },
