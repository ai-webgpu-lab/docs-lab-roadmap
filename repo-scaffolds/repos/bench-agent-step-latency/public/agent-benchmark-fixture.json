      ]
    },
    {
      "id": "queue-review-followup",
      "goal": "Queue a follow-up for the review card owner.",
      "steps": [
        { "id": "open-review-card", "tool": "open_panel", "target": "card.OPS-9", "latencyMs": 29, "effect": "Opened OPS-9 review card." },
        { "id": "copy-review-owner", "tool": "copy_field", "target": "OPS-9.owner", "latencyMs": 22, "effect": "Copied owner jules.", "draftLine": "OPS-9 owner: jules" },
        { "id": "queue-review", "tool": "queue_followup", "target": "browser-followup", "latencyMs": 38, "effect": "Queued browser follow-up for review owner.", "draftLine": "Queued follow-up for jules in browser-followup.", "failureKey": "queue-review", "fallbackDraftLine": "Follow-up queue handoff requires manual confirmation." }
      ]
    }
  ]
